{
  "name": "worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/worker/worker_app",
  "tags": ["type:app", "scope:worker"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": ".venv/bin/python -m celery -A worker_app.main:celery_app worker  --pool=threads --concurrency=4 --queues video,export --loglevel=info",
        "cwd": "apps/worker"
      }
    }
  }
}
