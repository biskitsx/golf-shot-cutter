{
  "name": "contracts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/contracts/src",
  "tags": ["type:lib", "scope:contracts"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
