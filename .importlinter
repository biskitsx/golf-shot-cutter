# Plan 1 scope: golf_domain + golf_application only.
# Plan 2 will add golf_infrastructure, golf_api, golf_worker — restore them
# (and the corresponding layer rows) when those packages exist.

[importlinter]
root_packages =
    golf_domain
    golf_application

[importlinter:contract:layered]
name = Clean Architecture layered dependency
type = layers
layers =
    golf_application
    golf_domain
